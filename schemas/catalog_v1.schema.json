{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zcx369658780/delayed-self-godot/main/schemas/catalog_v1.schema.json",
  "title": "Delayed Self Level Catalog Schema v1",
  "description": "Strict product routing and presentation catalog, separate from formal level_v1 puzzle data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog_version", "entries"],
  "properties": {
    "catalog_version": {"const": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "title_key": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level_id",
        "level_path",
        "sequence",
        "display_title_key",
        "classification",
        "unlock_prerequisites",
        "hud_mode",
        "final_level"
      ],
      "properties": {
        "level_id": {"$ref": "#/$defs/stable_id"},
        "level_path": {
          "type": "string",
          "pattern": "^res://data/levels/[a-z0-9_/-]+\\.json$"
        },
        "sequence": {"type": "integer", "minimum": 1, "maximum": 999},
        "display_title_key": {"$ref": "#/$defs/title_key"},
        "classification": {"enum": ["tutorial", "standard"]},
        "unlock_prerequisites": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stable_id"}
        },
        "hud_mode": {"enum": ["INTRO_MINIMAL", "GUIDED_ECHO", "STANDARD_COMPACT"]},
        "final_level": {"type": "boolean"},
        "best_turn_threshold": {"type": "integer", "minimum": 1}
      }
    }
  }
}
