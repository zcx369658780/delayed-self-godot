; Engine configuration file.
; Edited deliberately for the Task 0006 reusable application shell.

config_version=5

[application]

config/name="Delayed Self"
run/main_scene="res://scenes/app/app_root.tscn"

[display/window]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

move_up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":87), Object(InputEventKey,"keycode":4194320)]
}
move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":68), Object(InputEventKey,"keycode":4194321)]
}
move_down={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":83), Object(InputEventKey,"keycode":4194322)]
}
move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":65), Object(InputEventKey,"keycode":4194319)]
}
wait_turn={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32)]
}
restart_level={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":82)]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
